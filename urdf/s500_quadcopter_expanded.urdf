  </joint>
  <!-- RIGHT LANDING LEG -->
  <link name="landing_leg_right">
    <inertial>
      <mass value="0.001"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
    <!-- Horizontal skid tube (runs along X) -->
    <visual>
      <origin rpy="0 1.5708 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.240" radius="0.006"/>
      </geometry>
      <material name="landing_foam">
        <color rgba="0.15 0.15 0.15 1"/>
      </material>
    </visual>
    <!-- Red end-cap — front -->
    <visual>
      <origin rpy="0 1.5708 0" xyz="0.122 0 0"/>
      <geometry>
        <cylinder length="0.012" radius="0.0068"/>
      </geometry>
      <material name="landing_red">
        <color rgba="0.85 0.05 0.05 1"/>
      </material>
    </visual>
    <!-- Red end-cap — rear -->
    <visual>
      <origin rpy="0 1.5708 0" xyz="-0.122 0 0"/>
      <geometry>
        <cylinder length="0.012" radius="0.0068"/>
      </geometry>
      <material name="landing_red">
        <color rgba="0.85 0.05 0.05 1"/>
      </material>
    </visual>
    <!-- Front vertical strut -->
    <visual>
      <origin rpy="0 0 0" xyz="0.080 0 0.0415"/>
      <geometry>
        <cylinder length="0.083" radius="0.006"/>
      </geometry>
      <material name="landing_strut">
        <color rgba="0.12 0.12 0.12 1"/>
      </material>
    </visual>
    <!-- Rear vertical strut -->
    <visual>
      <origin rpy="0 0 0" xyz="-0.080 0 0.0415"/>
      <geometry>
        <cylinder length="0.083" radius="0.006"/>
      </geometry>
      <material name="landing_strut">
        <color rgba="0.12 0.12 0.12 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 1.5708 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.240" radius="0.006"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="landing_leg_right">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <joint name="landing_leg_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="landing_leg_right"/>
    <origin rpy="0 0 0" xyz="0 0.090 -0.095"/>
  </joint>
  <!-- ============================================================
       SENSORS AND PLUGINS
       ============================================================ -->
  <!-- IMU sensor — 100 Hz, matches spec sensors.imu.update_rate -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <topic>imu</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>
  <!-- Ground truth odometry -->
  <gazebo>
    <plugin filename="libgazebo_ros_p3d.so" name="p3d_base_controller">
      <ros>
        <remapping>~/out:=ground_truth/state</remapping>
      </ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.0</gaussian_noise>
      <update_rate>100</update_rate>
    </plugin>
  </gazebo>
</robot>
