<?xml version="1.0" ?>
<robot name="s500_quadcopter" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       S500 Quadcopter URDF
       Total mass  : 1.1 kg
       Wheelbase   : 500 mm (diagonal, motor-to-motor)
       Arm length  : 250 mm (centre to motor)
       Motor pos   : FR=[0.1768, 0.1768,0]  FL=[0.1768,-0.1768,0]
                     RR=[-0.1768,-0.1768,0] RL=[-0.1768, 0.1768,0]
       Propellers  : 10x5 inch  (radius 0.127 m)
       Motors      : DJI 2312 800KV
       ============================================================

       PHYSICS APPROACH
       The full system mass (1.1 kg) and spec inertia tensor are
       placed on base_link.  All other links carry token mass
       (0.001 kg) so their geometry renders correctly without
       distorting the dynamics.  This is standard practice for
       quadrotor URDF simulation (cf. PX4 iris.urdf.xacro).
       ============================================================ -->

  <!-- Inertia macros -->
  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertia
      ixx="${mass * (3*radius*radius + length*length) / 12}"
      ixy="0" ixz="0"
      iyy="${mass * (3*radius*radius + length*length) / 12}"
      iyz="0"
      izz="${mass * radius*radius / 2}"
    />
  </xacro:macro>

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertia
      ixx="${mass * (y*y + z*z) / 12}"
      ixy="0" ixz="0"
      iyy="${mass * (x*x + z*z) / 12}"
      iyz="0"
      izz="${mass * (x*x + y*y) / 12}"
    />
  </xacro:macro>

  <!-- Motor link macro — DJI 2312: bell dia 28 mm, stator dia 23 mm -->
  <xacro:macro name="motor_link" params="name">
    <link name="${name}">
      <inertial>
        <mass value="0.001"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:cylinder_inertia mass="0.001" radius="0.014" length="0.028"/>
      </inertial>
      <!-- Bell cap (silver) — upper -->
      <visual>
        <origin xyz="0 0 0.008" rpy="0 0 0"/>
        <geometry><cylinder radius="0.014" length="0.016"/></geometry>
        <material name="motor_bell"><color rgba="0.80 0.80 0.80 1"/></material>
      </visual>
      <!-- Stator (dark) — lower -->
      <visual>
        <origin xyz="0 0 -0.006" rpy="0 0 0"/>
        <geometry><cylinder radius="0.0115" length="0.012"/></geometry>
        <material name="motor_stator"><color rgba="0.20 0.20 0.20 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.014" length="0.028"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- ============================================================
       BASE LINK — S500 central frame
       Two carbon plates (165x165 mm) + standoffs + electronics stack
       Carries FULL system mass and spec inertia tensor.
       ============================================================ -->
  <link name="base_link">
    <inertial>
      <mass value="1.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- Full system inertia from spec (drone.inertia) -->
      <inertia
        ixx="0.0087" ixy="0.0" ixz="0.0"
        iyy="0.0087" iyz="0.0"
        izz="0.0144"
      />
    </inertial>
    <!-- Bottom carbon plate -->
    <visual>
      <origin xyz="0 0 -0.010" rpy="0 0 0"/>
      <geometry><box size="0.165 0.165 0.003"/></geometry>
      <material name="carbon"><color rgba="0.12 0.12 0.12 1"/></material>
    </visual>
    <!-- Top carbon plate -->
    <visual>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <geometry><box size="0.165 0.165 0.003"/></geometry>
      <material name="carbon"><color rgba="0.12 0.12 0.12 1"/></material>
    </visual>
    <!-- FC / electronics stack -->
    <visual>
      <origin xyz="0 0 0.012" rpy="0 0 0"/>
      <geometry><box size="0.055 0.055 0.028"/></geometry>
      <material name="fc_blue"><color rgba="0.10 0.25 0.70 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.165 0.165 0.025"/></geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ============================================================
       BATTERY — 4S LiPo  135x42x25 mm
       Mounted below bottom plate. Mass is cosmetic.
       ============================================================ -->
  <link name="battery">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.001" x="0.135" y="0.042" z="0.025"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.135 0.042 0.025"/></geometry>
      <material name="lipo"><color rgba="0.08 0.08 0.08 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.135 0.042 0.025"/></geometry>
    </collision>
  </link>

  <gazebo reference="battery"><material>Gazebo/Black</material></gazebo>

  <joint name="battery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery"/>
    <origin xyz="0 0 -0.024" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       ARMS — carbon fibre square tube 15x15 mm, 250 mm long
       Front (FR, FL) : ORANGE  — forward orientation marker
       Rear  (RR, RL) : DARK GREY
       Mass is cosmetic.
       ============================================================ -->

  <!-- FRONT RIGHT ARM -->
  <link name="arm_fr">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.001" x="0.25" y="0.015" z="0.015"/>
    </inertial>
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
      <material name="arm_front"><color rgba="1.0 0.40 0.0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
    </collision>
  </link>
  <gazebo reference="arm_fr"><material>Gazebo/Orange</material></gazebo>

  <!-- FRONT LEFT ARM -->
  <link name="arm_fl">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.001" x="0.25" y="0.015" z="0.015"/>
    </inertial>
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
      <material name="arm_front"><color rgba="1.0 0.40 0.0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
    </collision>
  </link>
  <gazebo reference="arm_fl"><material>Gazebo/Orange</material></gazebo>

  <!-- REAR RIGHT ARM -->
  <link name="arm_rr">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.001" x="0.25" y="0.015" z="0.015"/>
    </inertial>
    <visual>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
      <material name="arm_rear"><color rgba="0.20 0.20 0.20 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
    </collision>
  </link>
  <gazebo reference="arm_rr"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- REAR LEFT ARM -->
  <link name="arm_rl">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.001" x="0.25" y="0.015" z="0.015"/>
    </inertial>
    <visual>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
      <material name="arm_rear"><color rgba="0.20 0.20 0.20 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.015 0.015"/></geometry>
    </collision>
  </link>
  <gazebo reference="arm_rl"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- ARM JOINTS
       +45 deg (0.7854 rad) : FR / RR
       -45 deg (-0.7854 rad): FL / RL
       Motor world positions after rotation:
         FR=[ 0.1768, 0.1768,0]  FL=[ 0.1768,-0.1768,0]
         RR=[-0.1768,-0.1768,0]  RL=[-0.1768, 0.1768,0]  matches spec -->
  <joint name="arm_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fr"/>
    <origin xyz="0 0 0" rpy="0 0 0.7854"/>
  </joint>

  <joint name="arm_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fl"/>
    <origin xyz="0 0 0" rpy="0 0 -0.7854"/>
  </joint>

  <joint name="arm_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_rr"/>
    <origin xyz="0 0 0" rpy="0 0 0.7854"/>
  </joint>

  <joint name="arm_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_rl"/>
    <origin xyz="0 0 0" rpy="0 0 -0.7854"/>
  </joint>

  <!-- ============================================================
       MOTORS — DJI 2312 800KV
       Bell dia 28 mm x 16 mm (silver, upper)
       Stator dia 23 mm x 12 mm (dark, lower)
       Max RPM 6400 = 670 rad/s
       Mass is cosmetic.
       ============================================================ -->
  <xacro:motor_link name="motor_fr"/>
  <xacro:motor_link name="motor_fl"/>
  <xacro:motor_link name="motor_rr"/>
  <xacro:motor_link name="motor_rl"/>

  <gazebo reference="motor_fr"><material>Gazebo/Silver</material></gazebo>
  <gazebo reference="motor_fl"><material>Gazebo/Silver</material></gazebo>
  <gazebo reference="motor_rr"><material>Gazebo/Silver</material></gazebo>
  <gazebo reference="motor_rl"><material>Gazebo/Silver</material></gazebo>

  <!-- Motor joints — at arm tip, raised to sit on arm top surface
       z = half_arm_thickness (0.0075) + half_stator (0.006) = 0.015 m -->
  <joint name="motor_fr_joint" type="continuous">
    <parent link="arm_fr"/>
    <child link="motor_fr"/>
    <origin xyz="0.25 0 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="670"/>
  </joint>

  <joint name="motor_fl_joint" type="continuous">
    <parent link="arm_fl"/>
    <child link="motor_fl"/>
    <origin xyz="0.25 0 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="670"/>
  </joint>

  <joint name="motor_rr_joint" type="continuous">
    <parent link="arm_rr"/>
    <child link="motor_rr"/>
    <origin xyz="-0.25 0 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="670"/>
  </joint>

  <joint name="motor_rl_joint" type="continuous">
    <parent link="arm_rl"/>
    <child link="motor_rl"/>
    <origin xyz="-0.25 0 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="670"/>
  </joint>

  <!-- ============================================================
       PROPELLERS — 10x5 inch (radius 0.127 m)
       CW  props (FR, RL) : black
       CCW props (FL, RR) : dark grey  — distinguishable from above
       Mass is cosmetic.
       ============================================================ -->

  <!-- FR — CW — black -->
  <link name="prop_fr">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.001" radius="0.127" length="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
      <material name="prop_cw"><color rgba="0.05 0.05 0.05 0.90"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
    </collision>
  </link>
  <gazebo reference="prop_fr"><material>Gazebo/Black</material></gazebo>

  <!-- FL — CCW — dark grey -->
  <link name="prop_fl">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.001" radius="0.127" length="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
      <material name="prop_ccw"><color rgba="0.35 0.35 0.35 0.90"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
    </collision>
  </link>
  <gazebo reference="prop_fl"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- RR — CCW — dark grey -->
  <link name="prop_rr">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.001" radius="0.127" length="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
      <material name="prop_ccw"><color rgba="0.35 0.35 0.35 0.90"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
    </collision>
  </link>
  <gazebo reference="prop_rr"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- RL — CW — black -->
  <link name="prop_rl">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.001" radius="0.127" length="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
      <material name="prop_cw"><color rgba="0.05 0.05 0.05 0.90"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.127" length="0.008"/></geometry>
    </collision>
  </link>
  <gazebo reference="prop_rl"><material>Gazebo/Black</material></gazebo>

  <!-- Propeller joints — at top of motor bell (centre + 0.016 + 0.004 clearance) -->
  <joint name="prop_fr_joint" type="continuous">
    <parent link="motor_fr"/>
    <child link="prop_fr"/>
    <origin xyz="0 0 0.020" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_fl_joint" type="continuous">
    <parent link="motor_fl"/>
    <child link="prop_fl"/>
    <origin xyz="0 0 0.020" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_rr_joint" type="continuous">
    <parent link="motor_rr"/>
    <child link="prop_rr"/>
    <origin xyz="0 0 0.020" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_rl_joint" type="continuous">
    <parent link="motor_rl"/>
    <child link="prop_rl"/>
    <origin xyz="0 0 0.020" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ============================================================
       LANDING GEAR — two foam-wrapped skids with vertical struts
       Left skid  : y = -0.090 m
       Right skid : y = +0.090 m
       Struts at x = ±0.080 m, height 0.083 m
       Skid length 0.240 m, radius 6 mm
       Red end-caps match the real S500 landing gear foam tubes.
       ============================================================ -->

  <!-- LEFT LANDING LEG -->
  <link name="landing_leg_left">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
    <!-- Horizontal skid tube (runs along X) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.006" length="0.240"/></geometry>
      <material name="landing_foam"><color rgba="0.15 0.15 0.15 1"/></material>
    </visual>
    <!-- Red end-cap — front -->
    <visual>
      <origin xyz="0.122 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0068" length="0.012"/></geometry>
      <material name="landing_red"><color rgba="0.85 0.05 0.05 1"/></material>
    </visual>
    <!-- Red end-cap — rear -->
    <visual>
      <origin xyz="-0.122 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0068" length="0.012"/></geometry>
      <material name="landing_red"><color rgba="0.85 0.05 0.05 1"/></material>
    </visual>
    <!-- Front vertical strut -->
    <visual>
      <origin xyz="0.080 0 0.0415" rpy="0 0 0"/>
      <geometry><cylinder radius="0.006" length="0.083"/></geometry>
      <material name="landing_strut"><color rgba="0.12 0.12 0.12 1"/></material>
    </visual>
    <!-- Rear vertical strut -->
    <visual>
      <origin xyz="-0.080 0 0.0415" rpy="0 0 0"/>
      <geometry><cylinder radius="0.006" length="0.083"/></geometry>
      <material name="landing_strut"><color rgba="0.12 0.12 0.12 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.006" length="0.240"/></geometry>
    </collision>
  </link>

  <gazebo reference="landing_leg_left"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="landing_leg_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="landing_leg_left"/>
    <origin xyz="0 -0.090 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- RIGHT LANDING LEG -->
  <link name="landing_leg_right">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
    <!-- Horizontal skid tube (runs along X) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.006" length="0.240"/></geometry>
      <material name="landing_foam"><color rgba="0.15 0.15 0.15 1"/></material>
    </visual>
    <!-- Red end-cap — front -->
    <visual>
      <origin xyz="0.122 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0068" length="0.012"/></geometry>
      <material name="landing_red"><color rgba="0.85 0.05 0.05 1"/></material>
    </visual>
    <!-- Red end-cap — rear -->
    <visual>
      <origin xyz="-0.122 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0068" length="0.012"/></geometry>
      <material name="landing_red"><color rgba="0.85 0.05 0.05 1"/></material>
    </visual>
    <!-- Front vertical strut -->
    <visual>
      <origin xyz="0.080 0 0.0415" rpy="0 0 0"/>
      <geometry><cylinder radius="0.006" length="0.083"/></geometry>
      <material name="landing_strut"><color rgba="0.12 0.12 0.12 1"/></material>
    </visual>
    <!-- Rear vertical strut -->
    <visual>
      <origin xyz="-0.080 0 0.0415" rpy="0 0 0"/>
      <geometry><cylinder radius="0.006" length="0.083"/></geometry>
      <material name="landing_strut"><color rgba="0.12 0.12 0.12 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.006" length="0.240"/></geometry>
    </collision>
  </link>

  <gazebo reference="landing_leg_right"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="landing_leg_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="landing_leg_right"/>
    <origin xyz="0 0.090 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       SENSORS AND PLUGINS
       ============================================================ -->

  <!-- IMU sensor — 100 Hz, matches spec sensors.imu.update_rate -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <topic>imu</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>

  <!-- Ground truth odometry -->
  <gazebo>
    <plugin filename="libgazebo_ros_p3d.so" name="p3d_base_controller">
      <ros>
        <remapping>~/out:=ground_truth/state</remapping>
      </ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.0</gaussian_noise>
      <update_rate>100</update_rate>
    </plugin>
  </gazebo>

</robot>
