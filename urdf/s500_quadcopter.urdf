<?xml version="1.0" ?>
<robot name="s500_quadcopter" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Define inertia macros -->
  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertia
      ixx="${mass * (3 * radius * radius + length * length) / 12}"
      ixy="0" ixz="0"
      iyy="${mass * (3 * radius * radius + length * length) / 12}"
      iyz="0"
      izz="${mass * radius * radius / 2}"
    />
  </xacro:macro>

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertia
      ixx="${mass * (y*y + z*z) / 12}"
      ixy="0" ixz="0"
      iyy="${mass * (x*x + z*z) / 12}"
      iyz="0"
      izz="${mass * (x*x + y*y) / 12}"
    />
  </xacro:macro>

  <!-- BASE LINK (Body) -->
  <link name="base_link">
    <inertial>
      <mass value="0.45"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.45" x="0.15" y="0.15" z="0.05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.15 0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.15 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Gazebo materials for base_link -->
  <gazebo reference="base_link">
    <material>Gazebo/Black</material>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
  </gazebo>

  <!-- BATTERY -->
  <link name="battery">
    <inertial>
      <mass value="0.38"/>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.38" x="0.08" y="0.04" z="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.03"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.03"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="battery">
    <material>Gazebo/Red</material>
  </gazebo>

  <joint name="battery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- FRONT RIGHT ARM -->
  <link name="arm_fr">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
      <material name="carbon">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="arm_fr">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- FRONT LEFT ARM -->
  <link name="arm_fl">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
      <material name="carbon">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="arm_fl">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- REAR RIGHT ARM -->
  <link name="arm_rr">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
      <material name="carbon">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="arm_rr">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- REAR LEFT ARM -->
  <link name="arm_rl">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <xacro:box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
      <material name="carbon">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.02 0.02"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="arm_rl">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ARM JOINTS -->
  <joint name="arm_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fr"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <joint name="arm_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fl"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <joint name="arm_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_rr"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <joint name="arm_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_rl"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <!-- MOTORS -->
  <link name="motor_fr">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="motor_fr">
    <material>Gazebo/Grey</material>
  </gazebo>

  <link name="motor_fl">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="motor_fl">
    <material>Gazebo/Grey</material>
  </gazebo>

  <link name="motor_rr">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="motor_rr">
    <material>Gazebo/Grey</material>
  </gazebo>

  <link name="motor_rl">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="motor_rl">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- MOTOR JOINTS -->
  <joint name="motor_fr_joint" type="continuous">
    <parent link="arm_fr"/>
    <child link="motor_fr"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="100"/>
  </joint>

  <joint name="motor_fl_joint" type="continuous">
    <parent link="arm_fl"/>
    <child link="motor_fl"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="100"/>
  </joint>

  <joint name="motor_rr_joint" type="continuous">
    <parent link="arm_rr"/>
    <child link="motor_rr"/>
    <origin xyz="-0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="100"/>
  </joint>

  <joint name="motor_rl_joint" type="continuous">
    <parent link="arm_rl"/>
    <child link="motor_rl"/>
    <origin xyz="-0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="100"/>
  </joint>

  <!-- PROPELLERS -->
  <link name="prop_fr">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
      <material name="blade">
        <color rgba="0.1 0.1 0.1 0.8"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="prop_fr">
    <material>Gazebo/Black</material>
  </gazebo>

  <link name="prop_fl">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
      <material name="blade">
        <color rgba="0.1 0.1 0.1 0.8"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="prop_fl">
    <material>Gazebo/Black</material>
  </gazebo>

  <link name="prop_rr">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
      <material name="blade">
        <color rgba="0.1 0.1 0.1 0.8"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="prop_rr">
    <material>Gazebo/Black</material>
  </gazebo>

  <link name="prop_rl">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
      <material name="blade">
        <color rgba="0.1 0.1 0.1 0.8"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.127" length="0.01"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="prop_rl">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- PROPELLER JOINTS -->
  <joint name="prop_fr_joint" type="continuous">
    <parent link="motor_fr"/>
    <child link="prop_fr"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_fl_joint" type="continuous">
    <parent link="motor_fl"/>
    <child link="prop_fl"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_rr_joint" type="continuous">
    <parent link="motor_rr"/>
    <child link="prop_rr"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_rl_joint" type="continuous">
    <parent link="motor_rl"/>
    <child link="prop_rl"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- IMU SENSOR -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <topic>imu</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>

  <!-- GROUND TRUTH ODOMETRY -->
  <gazebo>
    <plugin filename="libgazebo_ros_p3d.so" name="p3d_base_controller">
      <ros>
        <remapping>~/out:=ground_truth/state</remapping>
      </ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.0</gaussian_noise>
      <update_rate>100</update_rate>
    </plugin>
  </gazebo>

</robot>
