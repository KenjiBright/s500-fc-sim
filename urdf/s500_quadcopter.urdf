<?xml version="1.0" ?>
<robot name="s500_quadcopter">
  <!-- S500 Quadcopter URDF Model -->

  <!-- Define inertia macros -->
  <macro name="cylinder_inertia" params="mass radius length">
    <inertia
      ixx="${mass * (3 * radius * radius + length * length) / 12}"
      ixy="0" ixz="0"
      iyy="${mass * (3 * radius * radius + length * length) / 12}"
      iyz="0"
      izz="${mass * radius * radius / 2}"
    />
  </macro>

  <macro name="box_inertia" params="mass x y z">
    <inertia
      ixx="${mass * (y*y + z*z) / 12}"
      ixy="0" ixz="0"
      iyy="${mass * (x*x + z*z) / 12}"
      iyz="0"
      izz="${mass * (x*x + y*y) / 12}"
    />
  </macro>

  <!-- BASE LINK -->
  <link name="base_link">
    <inertial>
      <mass value="0.45"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <box_inertia mass="0.45" x="0.15" y="0.15" z="0.05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.15 0.15 0.05"/></geometry>
      <material name="black"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.15 0.15 0.05"/></geometry>
    </collision>
  </link>

  <!-- BATTERY -->
  <link name="battery">
    <inertial>
      <mass value="0.38"/>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <box_inertia mass="0.38" x="0.08" y="0.04" z="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry><box size="0.08 0.04 0.03"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry><box size="0.08 0.04 0.03"/></geometry>
    </collision>
  </link>

  <joint name="battery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ARMS -->
  <link name="arm_fr">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
      <material name="carbon"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
    </collision>
  </link>

  <link name="arm_fl">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
      <material name="carbon"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
    </collision>
  </link>

  <link name="arm_rr">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
      <material name="carbon"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
    </collision>
  </link>

  <link name="arm_rl">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <box_inertia mass="0.08" x="0.25" y="0.02" z="0.02"/>
    </inertial>
    <visual>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
      <material name="carbon"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.02 0.02"/></geometry>
    </collision>
  </link>

  <joint name="arm_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fr"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="arm_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fl"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="arm_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_rr"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="arm_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_rl"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- MOTORS -->
  <link name="motor_fr">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
    </collision>
  </link>

  <link name="motor_fl">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
    </collision>
  </link>

  <link name="motor_rr">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
    </collision>
  </link>

  <link name="motor_rl">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.06" radius="0.01" length="0.03"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="motor_fr_joint" type="continuous">
    <parent link="arm_fr"/>
    <child link="motor_fr"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="motor_fl_joint" type="continuous">
    <parent link="arm_fl"/>
    <child link="motor_fl"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="motor_rr_joint" type="continuous">
    <parent link="arm_rr"/>
    <child link="motor_rr"/>
    <origin xyz="-0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="motor_rl_joint" type="continuous">
    <parent link="arm_rl"/>
    <child link="motor_rl"/>
    <origin xyz="-0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- PROPELLERS -->
  <link name="prop_fr">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
      <material name="blade"><color rgba="0.1 0.1 0.1 0.8"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
    </collision>
  </link>

  <link name="prop_fl">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
      <material name="blade"><color rgba="0.1 0.1 0.1 0.8"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
    </collision>
  </link>

  <link name="prop_rr">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
      <material name="blade"><color rgba="0.1 0.1 0.1 0.8"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
    </collision>
  </link>

  <link name="prop_rl">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <cylinder_inertia mass="0.05" radius="0.127" length="0.01"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
      <material name="blade"><color rgba="0.1 0.1 0.1 0.8"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.127" length="0.01"/></geometry>
    </collision>
  </link>

  <joint name="prop_fr_joint" type="continuous">
    <parent link="motor_fr"/>
    <child link="prop_fr"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_fl_joint" type="continuous">
    <parent link="motor_fl"/>
    <child link="prop_fl"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_rr_joint" type="continuous">
    <parent link="motor_rr"/>
    <child link="prop_rr"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="prop_rl_joint" type="continuous">
    <parent link="motor_rl"/>
    <child link="prop_rl"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
